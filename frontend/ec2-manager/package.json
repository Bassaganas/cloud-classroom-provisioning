{
  "name": "ec2-instance-manager",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "mock:server": "cd mock-server && npm start",
    "mock:dev": "cd mock-server && npm run dev",
    "dev:mock": "npm run mock:server & vite",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "test:e2e:features": "bddgen -c playwright.bdd.config.js && playwright test -c playwright.bdd.config.js",
    "test:e2e:features:list": "bddgen -c playwright.bdd.config.js && playwright test -c playwright.bdd.config.js --list",
    "test:e2e:features:headed": "bddgen -c playwright.bdd.config.js && playwright test -c playwright.bdd.config.js --headed",
    "test:e2e:features:report": "playwright show-report",
    "test:e2e:features:report:clean": "rm -rf playwright-report test-results"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "playwright-bdd": "^8.4.2",
    "vite": "^5.0.8"
  }
}
