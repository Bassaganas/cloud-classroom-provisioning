# ============================================================================
# AWS Credentials (DEV account)
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-west-1

# ============================================================================
# EC2 Manager Configuration
# ============================================================================
EC2_MANAGER_URL=https://ec2-management-dev.testingfantasy.com
EC2_MANAGER_PASSWORD=your_ec2_manager_password
WORKSHOP_NAME=fellowship
ENVIRONMENT=dev

# ============================================================================
# Route53 Configuration (needs to be populated from AWS account)
# ============================================================================
INSTANCE_MANAGER_HOSTED_ZONE_ID=Z00868603TVDTV1H4G9BU
INSTANCE_MANAGER_BASE_DOMAIN=testingfantasy.com

# ============================================================================
# Gitea Configuration
# ============================================================================
GITEA_URL=https://gitea.fellowship.testingfantasy.com
GITEA_LOCAL_URL=http://localhost:3000
GITEA_ADMIN_USER=gitea_admin
GITEA_ADMIN_PASSWORD=your_gitea_admin_password
# API token for webhook creation (create in Gitea UI if not available)
GITEA_API_TOKEN=your_gitea_api_token

# ============================================================================
# Jenkins Configuration
# ============================================================================
JENKINS_URL=https://jenkins.fellowship.testingfantasy.com
JENKINS_LOCAL_URL=http://localhost:8080
JENKINS_USER=your_jenkins_user
JENKINS_TOKEN=your_jenkins_token
JENKINS_CRUMB_ENABLED=true

# ============================================================================
# Test Environment Configuration
# ============================================================================
# 'deployed' for real AWS infrastructure, 'local' for docker-compose
TEST_ENVIRONMENT=deployed

# ============================================================================
# Lambda Configuration
# ============================================================================
CLEANUP_LAMBDA_NAME=classroom_admin_cleanup
STOP_INSTANCES_LAMBDA_NAME=classroom_stop_old_instances

# ============================================================================
# Test Configuration
# ============================================================================
TEST_HEADLESS=false
TEST_REQUIRE_UI=true
TEST_BROWSER=webkit
TEST_TIMEOUT=30000

# Playwright configuration
PLAYWRIGHT_SLOWMO=0
PLAYWRIGHT_DEBUG=false

# Test data (used for student creation)
TEST_STUDENT_A_USERNAME=test_student_a
TEST_STUDENT_B_USERNAME=test_student_b
TEST_ISOLATION_TIMEOUT=300  # 5 minutes to wait for resource isolation
TEST_WEBHOOK_TIMEOUT=120    # 2 minutes to wait for webhook trigger
TEST_PIPELINE_TIMEOUT=600   # 10 minutes to wait for pipeline completion
